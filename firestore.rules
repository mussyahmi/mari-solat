rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own user data (subcollections)
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Users top-level doc (alias storage)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Alias uniqueness registry — any auth user can read, owner can write/delete
    match /aliases/{aliasName} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null && resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && (resource == null || resource.data.uid == request.auth.uid);
    }

    // Challenge participants — any auth user can read, only owner can write
    match /challenge/{monthKey}/participants/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // FCM push notification tokens — owner can read/write/delete their own token
    match /fcm_tokens/{token} {
      allow create, update: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // Visitor analytics — public read, anyone can write their own visit (by uuid doc ID)
    match /visits/{uuid} {
      allow read: if true;
      allow create: if true;
    }

    // Global chat — any auth user can read/create, update for reports/moderation, owner can delete
    match /chat/{msgId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 300;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.uid;
    }

  }
}
